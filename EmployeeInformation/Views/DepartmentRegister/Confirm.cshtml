@using Csharp_training_202605.Presentations.ViewModels
@model DepartmentRegisterViewModel
@{
    ViewData["Title"] = "部署登録(確認)";
}
<h2 class="text-center mt-4">@ViewData["Title"]</h2>
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6 col-sm-8">
            <table class="table table-hover">
                <tbody>
                    
                    <tr>
                         @*EmployeeRegisterViewModelのDeptNameプロパティの値を表示する*@
                        <td class="fw-bold">@Html.DisplayNameFor(m => m.DeptName)</td>
                        <td>@Html.DisplayFor(m => m.DeptName)</td>
                    </tr>
                </tbody>
            </table>    

            <form>
                @*POSTリクエスト(Register/Back)に値を渡すためにhidden属性を使う*@
                @*これがないと、次の画面で値が消えてしまう*@
                <input type="hidden" asp-for="DeptName" />
                @*formaction/formmethod ボタンごとに送信先を変える*@
                @*同じフォーム内で[登録]と[戻る]を分岐できる*@
                <div class="text-center mt-4">
                    <button type="submit"
                        formaction="@Url.Action("Register", "DepartmentRegister")"
                        formmethod="post"
                        class="btn btn-primary">登録</button>
                    <button type="submit"
                        formaction="@Url.Action("Back", "DepartmentRegister")"
                        formmethod="post"
                        class="btn btn-secondary">戻る</button>
                </div>
            </form>
        </div>
    </div>
</div>